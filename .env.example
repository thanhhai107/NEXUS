# =============================================================================
# NEXUS Runtime Configuration
# =============================================================================
# NEXUS_RUNTIME_MODE: Determines the working directory mode
#   - "local"  : Use local runtime/ folder (default for development)
#   - "vm"     : Use /data/ folder (for AWS EC2 / GCP VM deployment)
# This is the PRIMARY way to switch between local and VM environments.
#
# NEXUS_RUNTIME_DIR: Override the base runtime directory (optional)
#   - For local mode: defaults to ./runtime
#   - For vm mode: defaults to /data
#
# Legacy env vars (still supported but deprecated):
#   - NEXUS_FORCE_GCP: Force VM mode (use NEXUS_RUNTIME_MODE=vm instead)
#   - NEXUS_FORCE_VM: Force VM mode (preferred alternative to NEXUS_FORCE_GCP)

NEXUS_RUNTIME_MODE=local
# NEXUS_RUNTIME_DIR=                    # Optional: override default runtime directory

# Airflow
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin

# Superset
SUPERSET_SECRET_KEY=change-me-for-production
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=admin

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
NEXUS_BUCKET=nexus-lakehouse
NEXUS_MINIO_VOLUME=minio-data

# Hive Metastore
HIVE_METASTORE_URI=thrift://hive-metastore:9083
NEXUS_HIVE_METASTORE_DB_VOLUME=hive-metastore-db-data

# Trino
TRINO_HOST=trino
TRINO_PORT=8080
TRINO_USER=nexus

# Governance
NEXUS_GOVERNANCE_STORAGE=local
NEXUS_GOVERNANCE_DATABASE_URL=postgresql://nexus_governance:nexus_governance@governance-db:5432/nexus_governance
NEXUS_AIRFLOW_DB_VOLUME=airflow-db-data
NEXUS_GOVERNANCE_DB_VOLUME=governance-db-data
NEXUS_SUPERSET_HOME_VOLUME=superset-home
NEXUS_ACTOR=local
NEXUS_GX_ENABLED=true

OPENLINEAGE_URL=
OPENLINEAGE_ENDPOINT=/api/v1/lineage
OPENLINEAGE_NAMESPACE=nexus
OPENLINEAGE_TIMEOUT_SECONDS=5
OPENLINEAGE_STRICT=false
MARQUEZ_TAG=0.51.1
MARQUEZ_PORT=5000
MARQUEZ_ADMIN_PORT=5001
MARQUEZ_WEB_PORT=3000
OPENMETADATA_SERVER_PORT=8585
OPENMETADATA_SERVER_ADMIN_PORT=8586
OPENMETADATA_INGESTION_PORT=8090
OPENMETADATA_ELASTICSEARCH_PORT=9201
OPENMETADATA_HEAP_OPTS=-Xmx1G -Xms1G

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_ADVERTISED_HOST=localhost
KAFKA_TOPIC_TRANSPORT_EVENTS=transport-events
NEXUS_STREAM_SOURCE=transport

# Spark
SPARK_MASTER=spark://spark:7077
SPARK_MASTER_URL=spark://spark:7077
SPARK_PROPERTIES_FILE=/opt/airflow/config/spark-defaults.conf
SPARK_DRIVER_HOST=
SPARK_DRIVER_BIND_ADDRESS=0.0.0.0
SPARK_DRIVER_PORT=
SPARK_BLOCKMANAGER_PORT=
SPARK_WORKER_CORES=2
SPARK_WORKER_MEMORY=2G
SPARK_LOCAL_DIRS=/data/spark
SPARK_EXECUTOR_CORES=
SPARK_EXECUTOR_MEMORY=
SPARK_DEFAULT_PARALLELISM=

# Transport streams
TRANSPORT_EVENTS_API_URL=
TRANSPORT_EVENTS_API_KEY=
TFL_API_URL=https://api.tfl.gov.uk/Line/Mode/tube,dlr,overground,elizabeth-line/Status
TFL_APP_ID=
TFL_API_KEY=
TFL_API_KEY_SECONDARY=
GTFS_REALTIME_URL=
GTFS_REALTIME_TYPE=vehicle_positions
GTFS_REALTIME_KEY=
SG_TRAFFIC_API_URL=https://api-open.data.gov.sg/v2/real-time/api/traffic-images
SG_API_KEY=

# Environment streams
OPENAQ_API_URL=https://api.openaq.org/v3/measurements
OPENAQ_API_KEY=
WAQI_API_URL=
WAQI_API_TOKEN=

# Optional schema discovery sources
OPENWEATHER_API_URL=https://api.openweathermap.org
OPENWEATHER_API_KEY=
NCEI_API_URL=https://www.ncei.noaa.gov
NCEI_API_TOKEN=
OPENMETEO_API_URL=https://air-quality-api.open-meteo.com
LONDONAIR_API_BASE_URL=https://api.erg.ic.ac.uk/AirQuality
DFT_ROAD_TRAFFIC_API_BASE_URL=https://roadtraffic.dft.gov.uk/api
NAPTAN_ACCESS_NODES_CSV_URL=
LONDON_PUBLIC_TRANSPORT_JOURNEYS_URL=
STATS19_COLLISIONS_CSV_URL=
STATS19_VEHICLES_CSV_URL=
STATS19_CASUALTIES_CSV_URL=
MOBILITYDATABASE_API_URL=https://api.mobilitydatabase.org
MOBILITYDATABASE_REFRESH_TOKEN=

# Governance agent LLM
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
NEXUS_AGENT_MODEL=gemini-2.5-flash

NEXUS_DLQ_TOPIC=nexus.dlq
NEXUS_PRODUCER_MAX_RETRIES=3
NEXUS_PRODUCER_RETRY_BACKOFF=0.5
NEXUS_CONSUMER_GROUP=nexus-streaming
NEXUS_STREAM_DATASET=transport_events
NEXUS_STREAM_TOPIC=transport-events
OPENLINEAGE_SPARK_PACKAGE=io.openlineage:openlineage-spark_2.12:1.21.0
DBT_PROFILES_DIR=/opt/airflow/transform/dbt

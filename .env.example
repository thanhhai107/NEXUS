# =============================================================================
# NEXUS Runtime Configuration
# =============================================================================
NEXUS_RUNTIME_MODE=local
NEXUS_RUNTIME_DIR=/data
NEXUS_DISTRIBUTED_MODE=true
NEXUS_LOCAL_WORKERS=4
NEXUS_GX_ENABLED=true
NEXUS_MINIO_VOLUME=/data/minio
NEXUS_REPOSITORY_URL=https://github.com/Akapi895/data-bigdata

# Airflow
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_DB_URL=postgresql+psycopg2://airflow:airflow@airflow-db:5432/airflow
AIRFLOW_CELERY_BROKER_URL=redis://:@redis:6379/0

# Superset
SUPERSET_SECRET_KEY=change-me-for-production
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=admin

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio-1:9000
NEXUS_BUCKET=nexus-lakehouse
NEXUS_RAW_BUCKET=data-lake-raw
NEXUS_WAREHOUSE_BUCKET=data-lake-warehouse
NEXUS_GOVERNANCE_BUCKET=data-lake-governance
MINIO_SECURE=false
AWS_REGION=us-east-1

# ZooKeeper
ZK_SERVERS=zookeeper-1:2888:3888;zookeeper-2:2888:3888;zookeeper-3:2888:3888
ZK_CONNECT=zookeeper-1:2181,zookeeper-2:2181,zookeeper-3:2181

# MinIO distributed peers
MINIO_PEERS=/data

# Hive Metastore
HIVE_METASTORE_URI=thrift://hive-metastore:9083

# Trino
TRINO_HOST=trino-coordinator
TRINO_PORT=8080
TRINO_USER=nexus
TRINO_DISCOVERY_URI=http://trino-coordinator:8080

# Governance
NEXUS_GOVERNANCE_STORAGE=local
NEXUS_ACTOR=local
NEXUS_GOVERNANCE_DATABASE_URL=postgresql://nexus_governance:nexus_governance@governance-db:5432/nexus_governance

# OpenLineage / Marquez / OpenMetadata
OPENLINEAGE_URL=
OPENLINEAGE_ENDPOINT=/api/v1/lineage
OPENLINEAGE_NAMESPACE=nexus
OPENLINEAGE_TIMEOUT_SECONDS=5
OPENLINEAGE_STRICT=false
OPENLINEAGE_PRODUCER_URL=https://github.com/nexus-lakehouse/nexus
OPENLINEAGE_SPARK_PACKAGE=io.openlineage:openlineage-spark_2.12:1.21.0
MARQUEZ_TAG=0.51.1
MARQUEZ_PORT=5000
MARQUEZ_ADMIN_PORT=5001
MARQUEZ_WEB_PORT=3000
OPENMETADATA_SERVER_PORT=8585
OPENMETADATA_SERVER_ADMIN_PORT=8586
OPENMETADATA_INGESTION_PORT=8090
OPENMETADATA_ELASTICSEARCH_PORT=9201
OPENMETADATA_HEAP_OPTS=-Xmx1G -Xms1G
OPENMETADATA_URL=
OPENMETADATA_STRICT=false
OPENMETADATA_TIMEOUT_SECONDS=30

# Kafka / Streaming
KAFKA_BOOTSTRAP_SERVERS=kafka-1:9092,kafka-2:9092,kafka-3:9092
NEXUS_CONSUMER_GROUP=nexus-streaming
NEXUS_DLQ_TOPIC=nexus.dlq

# Kafka Producer tuning
KAFKA_PRODUCER_ACKS=1
KAFKA_PRODUCER_RETRIES=3
KAFKA_PRODUCER_RETRY_BACKOFF_MS=100
KAFKA_PRODUCER_MAX_IN_FLIGHT=5
KAFKA_PRODUCER_COMPRESSION=gzip
KAFKA_PRODUCER_LINGER_MS=5
KAFKA_PRODUCER_BATCH_SIZE=16384
KAFKA_PRODUCER_MAX_BLOCK_MS=1000
KAFKA_PRODUCER_IDEMPOTENCE=false

# Kafka Consumer tuning
KAFKA_CONSUMER_AUTO_OFFSET_RESET=earliest
KAFKA_CONSUMER_AUTO_COMMIT=false
KAFKA_CONSUMER_AUTO_COMMIT_INTERVAL_MS=5000
KAFKA_CONSUMER_MAX_POLL_RECORDS=100
KAFKA_CONSUMER_MAX_POLL_INTERVAL_MS=300000
KAFKA_CONSUMER_SESSION_TIMEOUT_MS=10000
KAFKA_CONSUMER_HEARTBEAT_INTERVAL_MS=3000
KAFKA_CONSUMER_FETCH_MIN_BYTES=1
KAFKA_CONSUMER_FETCH_MAX_WAIT_MS=500
KAFKA_CONSUMER_MAX_PARTITION_FETCH_BYTES=1048576
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_SSL_CAFILE=
KAFKA_SSL_CERTFILE=
KAFKA_SSL_KEYFILE=

# Spark
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_WORKER_CORES=11
SPARK_WORKER_MEMORY=44G
SPARK_EXECUTOR_CORES=11
SPARK_EXECUTOR_MEMORY=44G
SPARK_DEFAULT_PARALLELISM=44
SPARK_SQL_SHUFFLE_PARTITIONS=44
SPARK_LOCAL_DIRS=/data/spark

# Cross-VM networking
NEXUS_MASTER_PRIVATE_IP=
NEXUS_NODE_IP=
NEXUS_REPO_PATH=
NEXUS_DOWNLOAD_ROOT=
NEXUS_RAW_ENVELOPE_REQUIRED=true
NEXUS_AIRFLOW_DOWNLOAD_RETRIES=3
NEXUS_AIRFLOW_DOWNLOAD_TIMEOUT_MINUTES=120
NEXUS_AIRFLOW_API_POOL=default_pool
NEXUS_DOWNLOADER_PATH=/opt/airflow/ingestion/downloaders

# Storage / Worker
STORAGE_RETRY_ATTEMPTS=3
STORAGE_RETRY_BACKOFF=1.0
NEXUS_RECORDS_PER_FILE=100000
NEXUS_BYTES_PER_FILE=104857600
NEXUS_SSH_OPTIONS=StrictHostKeyChecking=no,ConnectTimeout=10,BatchMode=yes
NEXUS_REMOTE_PYTHON_CMD=cd /opt/nexus/NEXUS && source .venv/bin/activate && python

# DBT
DBT_PROFILES_DIR=/opt/airflow/transform/dbt

# Governance Agent LLM (Amazon Bedrock)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
NEXUS_AGENT_MODEL=amazon.nova-pro-v1:0

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "College Scorecard",
  "type": "object",
  "required": [
    "id",
    "school_name",
    "latest_year"
  ],
  "properties": {
    "id": {
      "type": "integer"
    },
    "school_name": {
      "type": "string"
    },
    "latest_year": {
      "type": "integer"
    },
    "state": {
      "type": "string"
    },
    "admission_rate": {
      "type": "number"
    },
    "student_size": {
      "type": "integer"
    },
    "median_earnings": {
      "type": "number"
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Education Events",
  "type": "object",
  "required": [
    "event_id",
    "source",
    "event_type",
    "event_time"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "event_type": {
      "type": "string"
    },
    "event_time": {
      "type": "string"
    },
    "school_id": {
      "type": "string"
    },
    "country": {
      "type": "string"
    },
    "grade_level": {
      "type": "string"
    },
    "event_count": {
      "type": "integer"
    }
  }
}

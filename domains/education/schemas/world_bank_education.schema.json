{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "World Bank Education",
  "type": "object",
  "required": [
    "country_id",
    "country_name",
    "indicator_id",
    "indicator_name",
    "year"
  ],
  "properties": {
    "country_id": {
      "type": "string"
    },
    "country_name": {
      "type": "string"
    },
    "indicator_id": {
      "type": "string"
    },
    "indicator_name": {
      "type": "string"
    },
    "year": {
      "type": "integer"
    },
    "value": {
      "type": "number"
    }
  }
}

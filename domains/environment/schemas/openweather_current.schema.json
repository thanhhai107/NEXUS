{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenWeather Current Weather Reading",
  "type": "object",
  "properties": {
    "event_id": {"type": "string"},
    "source": {"type": "string"},
    "event_type": {"type": "string"},
    "event_time": {"type": "string"},
    "city_name": {"type": "string"},
    "latitude": {"type": ["string", "number"]},
    "longitude": {"type": ["string", "number"]},
    "temp": {"type": ["number", "null"]},
    "feels_like": {"type": ["number", "null"]},
    "pressure": {"type": ["integer", "null"]},
    "humidity": {"type": ["integer", "null"]},
    "wind_speed": {"type": ["number", "null"]},
    "wind_deg": {"type": ["integer", "null"]},
    "clouds": {"type": ["integer", "null"]},
    "visibility": {"type": ["integer", "null"]},
    "weather_main": {"type": ["string", "null"]},
    "weather_description": {"type": ["string", "null"]}
  },
  "required": ["event_id", "source", "event_type", "event_time"]
}

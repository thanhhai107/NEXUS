{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenMeteo Air Quality Reading",
  "type": "object",
  "properties": {
    "event_id": {"type": "string"},
    "source": {"type": "string"},
    "event_type": {"type": "string"},
    "event_time": {"type": "string"},
    "latitude": {"type": ["string", "number"]},
    "longitude": {"type": ["string", "number"]},
    "pm10": {"type": ["number", "null"]},
    "pm2_5": {"type": ["number", "null"]},
    "carbon_monoxide": {"type": ["number", "null"]},
    "nitrogen_dioxide": {"type": ["number", "null"]},
    "sulphur_dioxide": {"type": ["number", "null"]},
    "ozone": {"type": ["number", "null"]},
    "european_aqi": {"type": ["integer", "null"]},
    "us_aqi": {"type": ["integer", "null"]}
  },
  "required": ["event_id", "source", "event_type", "event_time", "latitude", "longitude"]
}

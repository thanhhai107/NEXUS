{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenAQ Measurements",
  "type": "object",
  "required": [
    "location_id",
    "location",
    "parameter",
    "value",
    "unit",
    "datetime"
  ],
  "properties": {
    "location_id": {
      "type": ["integer", "null"]
    },
    "location": {
      "type": ["string", "null"]
    },
    "parameter": {
      "type": ["string", "null"]
    },
    "value": {
      "type": ["number", "null"]
    },
    "unit": {
      "type": ["string", "null"]
    },
    "datetime": {
      "type": ["string", "null"]
    },
    "latitude": {
      "type": ["number", "null"]
    },
    "longitude": {
      "type": ["number", "null"]
    },
    "country": {
      "type": ["string", "null"]
    }
  }
}

{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "title": "Open-Meteo Historical Weather",
    "description": "Historical weather data from Open-Meteo Archive API for London bbox grid. Includes hourly temperature, precipitation, wind, pressure, radiation, and daily aggregates. Air quality variables include PM2.5, PM10, NO2, O3, CO, SO2, and European Aerosol Index.",
    "required": ["event_id", "source", "event_type", "event_time", "latitude", "longitude"],
    "properties": {
        "event_id": {"type": "string", "description": "Unique event identifier."},
        "source": {"type": "string", "description": "Source system identifier."},
        "event_type": {"type": "string", "description": "Type of event (e.g. csv_download)."},
        "event_time": {"type": "string", "format": "date-time", "description": "Event timestamp in ISO 8601 format."},
        "latitude": {"type": "number", "description": "Decimal latitude of grid point."},
        "longitude": {"type": "number", "description": "Decimal longitude of grid point."},
        "time": {"type": "string", "format": "date-time", "description": "Measurement time."},
        "temperature_2m": {"type": "number", "description": "Air temperature at 2m (\u00b0C)."},
        "relative_humidity_2m": {"type": "number", "description": "Relative humidity at 2m (%)."},
        "precipitation": {"type": "number", "description": "Total precipitation (mm)."},
        "wind_speed_10m": {"type": "number", "description": "Wind speed at 10m (km/h)."},
        "wind_direction_10m": {"type": "number", "description": "Wind direction at 10m (degrees)."},
        "surface_pressure": {"type": "number", "description": "Surface pressure (hPa)."},
        "cloud_cover": {"type": "number", "description": "Total cloud cover (%)."},
        "pm2_5": {"type": "number", "description": "PM2.5 concentration (\u03bcg/m\u00b3)."},
        "pm10": {"type": "number", "description": "PM10 concentration (\u03bcg/m\u00b3)."},
        "nitrogen_dioxide": {"type": "number", "description": "NO2 concentration (\u03bcg/m\u00b3)."},
        "ozone": {"type": "number", "description": "O3 concentration (\u03bcg/m\u00b3)."},
        "carbon_monoxide": {"type": "number", "description": "CO concentration (\u03bcg/m\u00b3)."},
        "sulphur_dioxide": {"type": "number", "description": "SO2 concentration (\u03bcg/m\u00b3)."}
    }
}

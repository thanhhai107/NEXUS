{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DfT Road Count Point",
  "type": "object",
  "properties": {
    "id": {"type": ["string", "integer"]},
    "count_point_id": {"type": ["string", "integer"]},
    "aadf_year": {"type": ["string", "integer", "null"]},
    "region_id": {"type": ["string", "integer", "null"]},
    "local_authority_id": {"type": ["string", "integer", "null"]},
    "road_name": {"type": ["string", "null"]},
    "road_category": {"type": ["string", "null"]},
    "road_type": {"type": ["string", "null"]},
    "easting": {"type": ["number", "integer", "null"]},
    "northing": {"type": ["number", "integer", "null"]},
    "latitude": {"type": ["number", "null"]},
    "longitude": {"type": ["number", "null"]},
    "link_length_km": {"type": ["number", "null"]},
    "link_length_miles": {"type": ["number", "null"]}
  },
  "required": ["count_point_id", "latitude", "longitude"]
}

{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "title": "TfL GIS London Transport Stations",
    "description": "London transport station points from TfL GIS Open Data Hub (ArcGIS REST FeatureServer). Layer 1: Underground Stations.",
    "required": ["OBJECTID", "NAME"],
    "properties": {
        "OBJECTID": {"type": "integer", "description": "Unique feature identifier."},
        "NAME": {"type": "string", "description": "Station name."},
        "LINES": {"type": "string", "description": "Serving tube lines (comma-separated)."},
        "ATCOCODE": {"type": "string", "description": "ATCO station code."},
        "MODES": {"type": "string", "description": "Transport modes served (e.g. bus, tube)."},
        "ACCESSIBILITY": {"type": "string", "description": "Accessibility status."},
        "NIGHT_TUBE": {"type": "string", "description": "Night tube service flag."},
        "NETWORK": {"type": "string", "description": "Operator network."},
        "DATASET_LAST_UPDATED": {"type": "integer", "description": "Last update timestamp (epoch ms)."},
        "FULL_NAME": {"type": "string", "description": "Full station name."}
    }
}

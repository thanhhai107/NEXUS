{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "title": "TfL GIS London Cycle Routes",
    "description": "London cycle route polylines from TfL GIS Open Data Hub (ArcGIS REST FeatureServer).",
    "required": ["OBJECTID", "Route_Name"],
    "properties": {
        "OBJECTID": {"type": "integer", "description": "Unique feature identifier."},
        "Label": {"type": "string", "description": "Route label (e.g. C)."},
        "Route_Name": {"type": "string", "description": "Cycle route name."},
        "Status": {"type": "string", "description": "Route status (e.g. Open)."},
        "Programme_": {"type": "integer", "description": "Last updated programme date (YYYYMMDD)."},
        "Programme": {"type": "string", "description": "Programme name (e.g. Cycleways)."},
        "Shape__Length": {"type": "number", "description": "Route length in metres."}
    }
}

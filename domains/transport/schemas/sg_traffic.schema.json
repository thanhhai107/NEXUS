{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Singapore Traffic",
  "type": "object",
  "required": [
    "event_id",
    "source",
    "event_type",
    "event_time"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "event_type": {
      "type": "string"
    },
    "event_time": {
      "type": "string"
    },
    "camera_id": {
      "type": "string"
    },
    "image_url": {
      "type": "string"
    },
    "latitude": {
      "type": "number"
    },
    "longitude": {
      "type": "number"
    }
  }
}

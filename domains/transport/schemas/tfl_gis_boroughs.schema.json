{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "title": "TfL GIS London Borough Boundaries",
    "description": "London borough boundary polygons from TfL GIS Open Data Hub (ArcGIS REST FeatureServer).",
    "required": ["OBJECTID", "BOROUGH", "CODE"],
    "properties": {
        "OBJECTID": {"type": "integer", "description": "Unique feature identifier."},
        "BOROUGH": {"type": "string", "description": "Borough name."},
        "NUMBER_": {"type": "string", "description": "Borough number code."},
        "CODE": {"type": "string", "description": "GSS borough code (e.g. 00AF)."},
        "HECTARES": {"type": "number", "description": "Borough area in hectares."},
        "DESCRIPT0": {"type": "string", "description": "Area description."},
        "X": {"type": "integer", "description": "OS easting centroid."},
        "Y": {"type": "integer", "description": "OS northing centroid."},
        "AREA": {"type": "number"},
        "FILE_NAME": {"type": "string"},
        "Shape__Area": {"type": "number"},
        "Shape__Length": {"type": "number"},
        "GlobalID": {"type": "string", "description": "ArcGIS global identifier."}
    }
}

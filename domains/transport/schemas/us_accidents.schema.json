{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "US Accidents",
  "type": "object",
  "required": [
    "ID",
    "Severity",
    "Start_Time",
    "Start_Lat",
    "Start_Lng",
    "State"
  ],
  "properties": {
    "ID": {
      "type": "string"
    },
    "Severity": {
      "type": "integer"
    },
    "Start_Time": {
      "type": "string",
      "format": "date-time"
    },
    "End_Time": {
      "type": "string",
      "format": "date-time"
    },
    "Start_Lat": {
      "type": "number"
    },
    "Start_Lng": {
      "type": "number"
    },
    "Distance(mi)": {
      "type": "number"
    },
    "Description": {
      "type": "string"
    },
    "City": {
      "type": "string"
    },
    "County": {
      "type": "string"
    },
    "State": {
      "type": "string"
    },
    "Weather_Timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "Weather_Condition": {
      "type": "string"
    }
  }
}

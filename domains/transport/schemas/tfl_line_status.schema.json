{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TfL Line Status",
  "type": "object",
  "required": [
    "event_id",
    "source",
    "event_type",
    "event_time",
    "line_id",
    "status",
    "severity"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "source": {
      "const": "tfl"
    },
    "event_type": {
      "const": "line_status"
    },
    "event_time": {
      "type": "string",
      "format": "date-time"
    },
    "line_id": {
      "type": ["string", "null"]
    },
    "line_name": {
      "type": ["string", "null"]
    },
    "status": {
      "type": ["string", "null"]
    },
    "severity": {
      "type": ["integer", "null"]
    },
    "reason": {
      "type": ["string", "null"]
    }
  }
}

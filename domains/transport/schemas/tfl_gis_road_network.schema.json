{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "title": "TfL GIS London Road Network",
    "description": "Transport for London Road Network (TLRN) polylines from TfL GIS Open Data Hub (ArcGIS REST FeatureServer).",
    "required": ["OBJECTID", "ROADLABEL"],
    "properties": {
        "OBJECTID": {"type": "integer", "description": "Unique feature identifier."},
        "UNIQUE_ID": {"type": "string", "description": "Unique internal ID."},
        "DATASET": {"type": "string", "description": "Source dataset name (e.g. TLRN)."},
        "TOID": {"type": "string", "description": "OS TOpographic IDentifier."},
        "NOT_USED": {"type": "string", "description": "Unused field."},
        "ROADLABEL": {"type": "string", "description": "Road name label."},
        "DESCTERM": {"type": "string", "description": "Road description/classification."},
        "NATURE": {"type": "string", "description": "Road nature (e.g. Dual Carriageway)."},
        "TLRN_DATE": {"type": "string", "description": "TLRN inclusion date."},
        "ROAD_TYPE": {"type": "string", "description": "Road type classification."},
        "ITN_DATE": {"type": "integer", "description": "ITN date (epoch ms)."},
        "EDITED_BY": {"type": "string", "description": "Last editor team."},
        "LAST_EDIT_DATE": {"type": "integer", "description": "Last edit timestamp (epoch ms)."},
        "Shape__Length": {"type": "number", "description": "Segment length in metres."}
    }
}

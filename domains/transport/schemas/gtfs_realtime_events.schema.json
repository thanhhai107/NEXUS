{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GTFS Realtime Events",
  "type": "object",
  "required": [
    "event_id",
    "source",
    "event_type",
    "event_time"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "event_type": {
      "type": "string"
    },
    "event_time": {
      "type": "string"
    },
    "feed_url": {
      "type": "string"
    },
    "feed_type": {
      "type": "string"
    },
    "entity_count": {
      "type": "integer"
    },
    "byte_size": {
      "type": "integer"
    }
  }
}

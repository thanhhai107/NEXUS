    "period_ending": {"type": "string"},
    "bus_journeys_m": {"type": ["string", "number", "null"]},
    "underground_journeys_m": {"type": ["string", "number", "null"]},
    "dlr_journeys_m": {"type": ["string", "number", "null"]},
    "tram_journeys_m": {"type": ["string", "number", "null"]},
    "overground_journeys_m": {"type": ["string", "number", "null"]},
    "london_cable_car_journeys_m": {"type": ["string", "number", "null"]},
    "tfl_rail_journeys_m": {"type": ["string", "number", "null"]}
  },
  "required": ["period_beginning", "reporting_period"]
}

datasets:
  transport_events:
    required_columns:
    - event_id
    - source
    - event_type
    - event_time
    freshness_column: event_time
  tfl_transport_status:
    required_columns:
    - event_id
    - source
    - event_type
    - event_time
    freshness_column: event_time
  tfl_line_status:
    required_columns:
    - event_id
    - source
    - event_type
    - event_time
    - line_id
    - status
    freshness_column: event_time
  tfl_arrivals:
    required_columns:
    - event_id
    - source
    - event_type
    - event_time
    - line_id
    - vehicle_id
    - expected_arrival
    freshness_column: expected_arrival
  gtfs_realtime_events:
    required_columns:
    - event_id
    - source
    - event_type
    - event_time
    freshness_column: event_time
  stats19_collisions:
    required_columns:
    - accident_index
    - accident_severity
    - latitude
    - longitude
    - date
    freshness_column: date
    auto_fix:
      trim_strings: true
      normalize_column_names: true
  naptan_stops:
    required_columns:
    - atcocode
    - commonname
    - latitude
    - longitude
    - stoptype
    freshness_column: modificationdatetime
    auto_fix:
      trim_strings: true
      normalize_column_names: true
  london_journeys:
    required_columns:
    - period_beginning
    - reporting_period
    freshness_column: period_beginning
    auto_fix:
      trim_strings: true
      normalize_column_names: true
  dft_road_traffic:
    required_columns:
    - count_point_id
    - latitude
    - longitude
    freshness_column: aadf_year
    auto_fix:
      trim_strings: true
      normalize_column_names: true

  tfl_gis_boroughs:
    required_columns:
    - OBJECTID
    - BOROUGH
    - CODE
    freshness_column: null
    primary_keys:
    - OBJECTID

  tfl_gis_cycle_routes:
    required_columns:
    - OBJECTID
    - Route_Name
    freshness_column: null
    primary_keys:
    - OBJECTID

  tfl_gis_road_network:
    required_columns:
    - OBJECTID
    - ROAD_NAME
    freshness_column: null
    primary_keys:
    - OBJECTID

  tfl_gis_stations:
    required_columns:
    - OBJECTID
    - NAME
    - LATITUDE
    - LONGITUDE
    freshness_column: null
    primary_keys:
    - OBJECTID

  overture_transportation:
    required_columns:
    - id
    - subtype
    - class
    freshness_column: null
    primary_keys:
    - id


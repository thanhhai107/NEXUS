datasets:
  transport_events:
    glossary:
      dataset_term: Transport Incident Event
      field_terms:
        event_id: Source Event Identifier
        event_time: Incident Event Time
        event_type: Incident Type
        severity: Incident Severity
        state: Administrative Area
    field_mappings:
      - source_field: event_time
        canonical_field: event_time
        issue: different_timestamp_timezone_grain
        time_role: event_time
      - source_field: state
        canonical_field: administrative_area
        issue: same_name_different_meaning
    standards:
      time:
        event_time_field: event_time
        ingestion_time_field: _nexus_ingested_at
        processing_time_field: _nexus_silver_loaded_at
        source_timezone: UTC
        storage_timezone: UTC
        timezone_standard: IANA
        timestamp_format: ISO 8601
      spatial:
        latitude_field: latitude
        longitude_field: longitude
        source_crs: EPSG:4326
        storage_crs: EPSG:4326
        render_crs: EPSG:3857
    grain:
      entity_grain:
        - event_id
      time_grain: event_timestamp
      spatial_grain: point_or_administrative_area
      aggregation_level: raw_event
      compatible_gold_grains:
        - hour_state_event_type
    entity_matching:
      entity_type: transport_incident
      source_id_fields:
        - event_id
      candidate_fields:
        - event_type
        - event_time
        - latitude
        - longitude
      canonical_entity_id_field: canonical_entity_id
      methods:
        - exact
        - rule_based
        - fuzzy
        - probabilistic
        - splink
        - llm_assisted_review
  naptan_stops:
    glossary:
      dataset_term: Public Transport Stop
      field_terms:
        atcocode: Stop Identifier
        commonname: Stop Name
        latitude: Stop Latitude
        longitude: Stop Longitude
    standards:
      spatial:
        latitude_field: latitude
        longitude_field: longitude
        source_crs: EPSG:4326
        storage_crs: EPSG:4326
        render_crs: EPSG:3857
    grain:
      entity_grain:
        - atcocode
      time_grain: slowly_changing_reference
      spatial_grain: stop_point
      aggregation_level: reference_entity
    entity_matching:
      entity_type: transit_stop
      source_id_fields:
        - atcocode
      candidate_fields:
        - commonname
        - latitude
        - longitude
      canonical_entity_id_field: canonical_entity_id
      methods:
        - exact
        - rule_based
        - fuzzy
        - probabilistic
        - splink
        - llm_assisted_review
  london_journeys:
    glossary:
      dataset_term: Public Transport Journey Count
      field_terms:
        period_beginning: Reporting Period Start
        reporting_period: Reporting Period Type
    standards:
      time:
        event_time_field: period_beginning
        source_timezone: Europe/London
        storage_timezone: UTC
        timezone_standard: IANA
        timestamp_format: ISO 8601
    grain:
      entity_grain:
        - period_beginning
        - reporting_period
      time_grain: reporting_period
      spatial_grain: greater_london
      aggregation_level: aggregate_period
    definitions:
      journey_count: Aggregate public-transport journeys by reporting period; do not join to event-level trips without allocation.
  tfl_transport_status:
    glossary:
      dataset_term: TfL Transport Status Event
      field_terms:
        line_id: Line Identifier
        line_name: Line Name
        status: Line Status
        severity: Disruption Severity
        reason: Disruption Reason
    field_mappings:
      - source_field: event_time
        canonical_field: event_time
        issue: different_timestamp_timezone_grain
        time_role: event_time
      - source_field: line_id
        canonical_field: transport_line_id
        issue: different_name_same_meaning
    standards:
      time:
        event_time_field: event_time
        ingestion_time_field: _nexus_ingested_at
        source_timezone: Europe/London
        storage_timezone: UTC
        timezone_standard: IANA
        timestamp_format: ISO 8601
      spatial:
        source_crs: EPSG:4326
        storage_crs: EPSG:4326
        render_crs: EPSG:3857
    grain:
      entity_grain:
        - line_id
        - status
      time_grain: line_status_event
      spatial_grain: line
      aggregation_level: realtime_snapshot
    definitions:
      status: TfL line status describes operational condition, not incident lifecycle.
    entity_matching:
      entity_type: transport_line
      source_id_fields:
        - line_id
      candidate_fields:
        - line_name
        - status
      canonical_entity_id_field: canonical_entity_id
      methods:
        - exact
        - rule_based
        - fuzzy
        - probabilistic
        - splink
        - llm_assisted_review
  tfl_line_status:
    glossary:
      dataset_term: TfL Line Status Event
      field_terms:
        line_id: Line Identifier
        line_name: Line Name
        status: Line Status
        severity: Status Severity Code
        reason: Disruption Reason
    field_mappings:
      - source_field: event_time
        canonical_field: event_time
        issue: different_timestamp_timezone_grain
        time_role: event_time
      - source_field: line_id
        canonical_field: transport_line_id
        issue: different_name_same_meaning
    standards:
      time:
        event_time_field: event_time
        ingestion_time_field: _nexus_ingested_at
        source_timezone: Europe/London
        storage_timezone: UTC
        timezone_standard: IANA
        timestamp_format: ISO 8601
      spatial:
        source_crs: EPSG:4326
        storage_crs: EPSG:4326
        render_crs: EPSG:3857
    grain:
      entity_grain:
        - line_id
        - status
      time_grain: line_status_poll
      spatial_grain: line
      aggregation_level: realtime_snapshot
    definitions:
      status: Operational condition for a TfL public transport line at poll time.
    entity_matching:
      entity_type: transport_line
      source_id_fields:
        - line_id
      candidate_fields:
        - line_name
        - status
      canonical_entity_id_field: canonical_entity_id
      methods:
        - exact
        - rule_based
        - fuzzy
  tfl_arrivals:
    glossary:
      dataset_term: TfL Arrival Prediction
      field_terms:
        stop_id: StopPoint Identifier
        vehicle_id: Vehicle Identifier
        line_id: Line Identifier
        expected_arrival: Expected Arrival Time
        time_to_station: Seconds To Arrival
    field_mappings:
      - source_field: expected_arrival
        canonical_field: event_time
        issue: different_name_same_meaning
        time_role: event_time
      - source_field: stop_id
        canonical_field: stop_point_id
        issue: different_name_same_meaning
      - source_field: line_id
        canonical_field: transport_line_id
        issue: different_name_same_meaning
    standards:
      time:
        event_time_field: expected_arrival
        ingestion_time_field: prediction_time
        source_timezone: UTC
        storage_timezone: UTC
        timezone_standard: IANA
        timestamp_format: ISO 8601
    grain:
      entity_grain:
        - vehicle_id
        - line_id
        - expected_arrival
      time_grain: arrival_prediction
      spatial_grain: stop_point
      aggregation_level: realtime_prediction
    definitions:
      time_to_station: Countdown in seconds from the poll time until predicted vehicle arrival.
    entity_matching:
      entity_type: public_transport_vehicle_arrival
      source_id_fields:
        - vehicle_id
        - line_id
        - expected_arrival
      candidate_fields:
        - station_name
        - destination_name
      canonical_entity_id_field: canonical_entity_id
      methods:
        - exact
        - rule_based
  gtfs_realtime_events:
    glossary:
      dataset_term: GTFS Realtime Event
      field_terms:
        event_id: Feed Event Identifier
        event_time: Feed Poll Event Time
        feed_url: Feed URL
        byte_size: Feed Byte Size
    field_mappings:
      - source_field: event_time
        canonical_field: event_time
        issue: different_timestamp_timezone_grain
        time_role: event_time
    standards:
      time:
        event_time_field: event_time
        ingestion_time_field: _nexus_ingested_at
        source_timezone: UTC
        storage_timezone: UTC
        timezone_standard: IANA
        timestamp_format: ISO 8601
    grain:
      entity_grain:
        - event_id
      time_grain: feed_poll
      spatial_grain: feed
      aggregation_level: feed_snapshot
  stats19_collisions:
    glossary:
      dataset_term: Road Collision Record
      field_terms:
        accident_index: Accident Identifier
        accident_severity: Accident Severity
        latitude: Collision Latitude
        longitude: Collision Longitude
        date: Accident Event Date
    field_mappings:
      - source_field: accident_index
        canonical_field: accident_id
        issue: different_name_same_meaning
      - source_field: date
        canonical_field: event_date
        issue: different_timestamp_timezone_grain
        time_role: event_time
    standards:
      units:
        dimension_type: speed
        canonical_unit: km/h
        value_field: speed_limit
        converted_value_field: speed_limit_kmh
        implicit_source_unit: mph
        expected_range:
          min: 0
          max: 140
      time:
        event_time_field: date
        ingestion_time_field: _nexus_ingested_at
        source_timezone: Europe/London
        storage_timezone: UTC
        timezone_standard: IANA
        timestamp_format: ISO 8601
      spatial:
        latitude_field: latitude
        longitude_field: longitude
        source_crs: EPSG:4326
        storage_crs: EPSG:4326
        render_crs: EPSG:3857
    grain:
      entity_grain:
        - accident_index
      time_grain: accident_day
      spatial_grain: collision_point
      aggregation_level: raw_event
  dft_road_traffic:
    glossary:
      dataset_term: Road Traffic Count Point
      field_terms:
        count_point_id: Count Point Identifier
        aadf_year: Traffic Count Year
        latitude: Count Point Latitude
        longitude: Count Point Longitude
        link_length_km: Link Length Kilometers
    field_mappings:
      - source_field: count_point_id
        canonical_field: count_point_id
        issue: same_name_different_meaning
      - source_field: aadf_year
        canonical_field: event_year
        issue: different_timestamp_timezone_grain
        time_role: event_time
    standards:
      units:
        dimension_type: distance
        canonical_unit: km
        value_field: link_length_miles
        converted_value_field: link_length_km_canonical
        implicit_source_unit: mi
        expected_range:
          min: 0
          max: 100
      time:
        event_time_field: aadf_year
        ingestion_time_field: _nexus_ingested_at
        source_timezone: UTC
        storage_timezone: UTC
        timezone_standard: IANA
        timestamp_format: ISO 8601
      spatial:
        latitude_field: latitude
        longitude_field: longitude
        source_crs: EPSG:4326
        storage_crs: EPSG:4326
        render_crs: EPSG:3857
    grain:
      entity_grain:
        - count_point_id
        - aadf_year
      time_grain: year
      spatial_grain: count_point
      aggregation_level: annual_count

  tfl_gis_boroughs:
    glossary_terms:
      - term: OBJECTID
        definition: ArcGIS unique feature identifier.
      - term: BOROUGH
        definition: London borough name.
      - term: CODE
        definition: GSS borough code.
    grain: per_borough
    timestamp_column: null
    crs: EPSG:27700

  tfl_gis_cycle_routes:
    glossary_terms:
      - term: OBJECTID
        definition: ArcGIS unique feature identifier.
      - term: Route_Name
        definition: Cycle route name.
      - term: Status
        definition: Route operational status.
    grain: per_route_segment
    timestamp_column: null
    crs: EPSG:27700

  tfl_gis_road_network:
    glossary_terms:
      - term: OBJECTID
        definition: ArcGIS unique feature identifier.
      - term: ROAD_NAME
        definition: Road name.
      - term: ROAD_CLASS
        definition: Road classification.
    grain: per_road_segment
    timestamp_column: null
    crs: EPSG:27700

  tfl_gis_stations:
    glossary_terms:
      - term: OBJECTID
        definition: ArcGIS unique feature identifier.
      - term: NAME
        definition: Station name.
      - term: MODE
        definition: Transport mode.
      - term: LATITUDE
        definition: WGS84 latitude.
      - term: LONGITUDE
        definition: WGS84 longitude.
    grain: per_station
    timestamp_column: null
    crs: EPSG:4326

  overture_transportation:
    glossary_terms:
      - term: id
        definition: Overture Maps GERS unique feature identifier.
      - term: subtype
        definition: Feature subtype (road, path, track).
      - term: class
        definition: Road classification (primary, secondary, motorway, etc.).
      - term: names_primary
        definition: Primary street or road name.
      - term: road
        definition: Road number or designation (e.g. A40, M25).
      - term: surface
        definition: Road surface material.
    grain: per_road_segment
    timestamp_column: null
    crs: EPSG:4326
